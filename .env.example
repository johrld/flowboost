# FlowBoost - Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Backend (Fastify API) ──────────────────────────────────────
PORT=6100
LOG_LEVEL=debug
DATA_DIR=./backend/data

# ── AI Services ──────────────────────────────────────────────
# Anthropic — required for content pipeline (Claude Agent SDK)
# Either mount Claude CLI credentials (dev) or set API key (prod)
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini — required for image generation (Imagen)
GEMINI_API_KEY=

# ── Frontend (Next.js Dashboard) ───────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:6100
FRONTEND_PORT=6101

# ── GitHub App (optional — for GitHub connector) ──────────────
# Create a GitHub App: https://github.com/settings/apps/new
# Required permissions: Contents (read/write), Pull Requests (read/write)
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=
# Base64-encoded private key: cat your-app.pem | base64 -w0
GITHUB_PRIVATE_KEY_BASE64=
