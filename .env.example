# FlowBoost — Environment Configuration
# Copy this file: cp .env.example .env

# ── Backend (Fastify API) ────────────────────────────────────
PORT=6100
LOG_LEVEL=debug
DATA_DIR=./backend/data

# ── Authentication ───────────────────────────────────────────
# FlowBoost uses the Claude Agent SDK, which runs Claude Code CLI
# as a subprocess. The CLI needs credentials to call the Anthropic API.
#
# Option 1: API Key (recommended)
#   Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
#
# Option 2: Claude Code CLI credentials (Max subscription)
#   If you're logged in via `claude` CLI and have a Max subscription,
#   mount your credentials into the container instead of setting an API key.
#   See docker-compose.override.example.yml for details.

# ── Image Generation (optional) ──────────────────────────────
# Google Gemini — powers hero image generation via Imagen 4.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Frontend (Next.js Dashboard) ─────────────────────────────
FRONTEND_PORT=6101

# ── GitHub App (optional) ────────────────────────────────────
# Only needed if you use the GitHub connector to publish content.
# Create a GitHub App: https://github.com/settings/apps/new
# Required permissions: Contents (read/write), Pull Requests (read/write)
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=
# Base64-encoded private key: cat your-app.pem | base64 -w0
GITHUB_PRIVATE_KEY_BASE64=
