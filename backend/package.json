{
  "name": "flowboost",
  "version": "0.1.0",
  "description": "AI-powered content generation service",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "typecheck": "tsc --noEmit",
    "pipeline": "tsx scripts/pipeline.ts",
    "watch": "tsx scripts/watch.ts",
    "migrate": "tsx scripts/migrate-to-nested.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.63",
    "@fastify/cors": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "fastify": "^5.0.0",
    "jsonwebtoken": "^9.0.3",
    "pino": "^9.0.0",
    "sharp": "^0.34.5",
    "simple-git": "^3.27.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/sharp": "^0.31.1",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  }
}
